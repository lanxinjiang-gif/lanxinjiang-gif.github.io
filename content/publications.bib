@inproceedings{jiang2022fraud,
  order = {4},
  title = {Towards Real-Time Financial Statement Fraud Detection Using Machine Learning},
  author = {Lanxin Jiang and Miklos Vasarhelyi and Chanyuan A. Parker},
  year = {2022},
  booktitle = {PCAOB Conference on Auditing and Capital Markets},
  url = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4003621},
  abstract = {This study develops a real-time financial statement fraud detection approach. Because traditional models rely on future fraud disclosures, they are less effective in real-time settings. We propose a machine learning method that accounts for delayed fraud identification through selection bias estimation. The method outperforms existing approaches, improving the accuracy and cost-effectiveness of real-time fraud detection, with important implications for research and practice.},
  keywords = {Machine Learning, Financial Statement Fraud, Audit, Real-Time Detection}
}

@misc{jiang2022restatements,
  nobibtex = {true},
  title = {Refining Abnormal Accrual Estimates: A Machine Learning Approach},
  author = {Yu Gu and Lanxin Jiang and Chanyuan Abigail Zhang Parker and Lei Zhao},
  year = {2022},
  abstract = {This study examines whether machine learning can improve the construct validity of abnormal accrual estimates. We compare abnormal accruals derived from machine learning with those produced by traditional linear regression models. We find that machine learning–based measures are more economically plausible and more effective in identifying material misstatements, fraud, and other manipulations. Overall, the study advances accrual modeling and offers a more precise measure for research on earnings management, financial reporting quality, and audit quality.},
  keywords = {Semi-Supervised Learning, Restatements, Audit, Machine Learning}
}

