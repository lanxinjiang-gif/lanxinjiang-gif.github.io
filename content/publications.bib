@article{parker2025misstatements,
  selected={true},
  order = {1},
  title = {Predicting Material Misstatements Using Machine Learning},
  author = {Chanyuan Zhang Parker and Lanxin Jiang and Soohyun Cho and Miklos A. Vasarhelyi},
  year = {2025},
  journal = {The Accounting Review},
  volume = {100},
  number = {6},
  pages = {225--262},
  doi = {10.2308/TAR-2024-0035},
  abstract = {This study develops a dynamic machine learning model to forecast material misstatements. Using raw financial data, audit variables, and qualitative features, the model outperforms benchmarks in one-year-ahead and two-year-ahead forecasts, both in out-of-sample predictive power and economic impact on net income. Explainable AI identifies the key predictive features. The findings show that the model helps investors outperform reactive detection strategies, enables managers to address internal control weaknesses earlier, supports auditors' advance risk assessments, and helps regulators allocate inspection resources proactively.},
  
  keywords = {Machine Learning, Material Misstatements, Audit, Accounting}
}

@article{gu2026greenwashing,
  selected={true},
  order = {2},
  title = {Using Blockchain and Smart Contracts to Combat Greenwashing in Environmental Disclosures},
  author = {Yu Gu and Lanxin Jiang and Jun Dai},
  year = {2026},
  journal = {Accounting Horizons},
  pages = {1--24},
  doi = {10.2308/HORIZONS-2023-099},
  abstract = {We examine common greenwashing risks and propose a blockchain-based framework to combat greenwashing. We define six types of greenwashing risks in environmental disclosures: misconduct, selective disclosure, misclassification, hollow promise, in name only, and misleading presentation. We propose and implement a framework that integrates blockchain and smart contracts to create automated controls and provide tamper-resistant audit evidence.},
  
  keywords = {Blockchain, Smart Contracts, Greenwashing, Environmental Disclosures, ESG}
}

@article{jiang2023esg,
  selected={true},
  order = {5},
  title = {Environmental, Social, and Governance Taxonomy Simplification: A Hybrid Text Mining Approach},
  author = {Lanxin Jiang and Yu Gu and Jun Dai},
  year = {2023},
  journal = {Journal of Emerging Technologies in Accounting},
  volume = {20},
  number = {1},
  pages = {305--325},
  url = {http://publications.aaahq.org/jeta/article/20/1/305/10895},
  abstract = {This paper proposes a hybrid methodology for extracting simplified, ex post, and dynamic taxonomies based on existing ESG standards and reports to improve the comparability of ESG reporting. An example of deriving a simplified environmental taxonomy from European companies' ESG reports and the Global Reporting Initiative (GRI) standards illustrates the proposed methodology.},
  
  keywords = {ESG, Text Mining, Machine Learning, Accounting, Taxonomy}
}

@article{zhang2023iot,
  title = {Internet of Things and Blockchain-Based Smart Contracts: Enabling Continuous Risk Monitoring and Assessment in Peer-to-Peer Lending},
  author = {Z. Zhang and Yu Gu and Lanxin Jiang and W. Yu and Jun Dai},
  year = {2023},
  journal = {Journal of Emerging Technologies in Accounting},
  volume = {20},
  number = {2},
  pages = {181--194},
  doi = {10.2308/JETA-2022-003},
  abstract = {Peer-to-peer (P2P) lending bypasses traditional financial intermediaries but faces high delinquency risk and weak risk control. This study examines how IoT, blockchain, smart contracts, and a Continuous Risk Monitoring and Assessment (CRMA) framework can improve risk management. Using a case study of a Chinese P2P platform, it proposes an IoT-enabled smart contract system for real-time monitoring, automated loan settlement, and timely risk disclosure.},
  keywords = {Internet of Things, Blockchain, Smart Contracts, Risk Monitoring, Peer-to-Peer Lending}
}

@misc{jiang2023gets,
  order = {3},
  year = {2023},
  title = {A Greenhouse Gas Emission Tracking System (GETS) for Climate-Related Disclosures},
  author = {Lanxin Jiang and Yu Gu and W. Yu and Jun Dai},
  howpublished = {Available at SSRN 4409535},
  url = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4409535},
  abstract = {Scope 3 greenhouse gas (GHG) emissions are vital components of climate risk metrics, but they are challenging to estimate due to the lack of proper estimation methods and the difficulty in collecting data throughout the entire value chain. We propose a system incorporating the Internet of Things (IoT), blockchain, and Life Cycle Assessment (LCA) to enhance Scope 3 GHG reporting. The system enables reliable data collection from various sources and comprehensive estimation of Scope 3 GHG emissions.},
  keywords = {Greenhouse Gas, Climate Disclosure, Tracking System, ESG, Sustainability}
}

